{
  "name": "sql-script-generator",
  "version": "1.0.6",
  "description": "SQL脚本生成工具，用于快速生成符合规范的SQL脚本文件。",
  "main": "./out/main/index.js",
  "author": "lov3smu <imancoka@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:win": "electron-vite build && electron-builder --win --x64",
    "build:linux": "electron-vite build && electron-builder --linux --x64",
    "build:mac": "electron-vite build && electron-builder --mac --x64",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "electron-log": "^5.0.1",
    "electron-updater": "^6.1.7",
    "js-yaml": "^4.1.1",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "electron": "^41.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.2"
  },
  "build": {
    "appId": "com.ancoka.sql-script-generator",
    "productName": "SqlScriptGenerator",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      "icon": "assets/icon.ico",
      "signtoolOptions": {
        "publisherName": "lov3smu"
      }
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "tar.gz"
      ],
      "icon": "assets/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "perMachine": true,
      "installerHeaderIcon": "assets/icon.ico",
      "license": "LICENSE.txt",
      "deleteAppDataOnUninstall": true
    },
    "publish": {
      "provider": "github",
      "owner": "lov3smu",
      "repo": "sql-script-generator",
      "releaseType": "release"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
