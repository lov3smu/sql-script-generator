{
  "name": "sql-script-generator",
  "version": "1.0.0",
  "description": "SQL Script Generator Tool",
  "main": "main.js",
  "scripts": {
      "start": "electron .",
      "build": "echo 'Building...'",
      "build:linux": "electron-builder --linux --x64",
      "build:win": "electron-builder --win --x64",
      "build:mac": "electron-builder --mac --x64"
  },
  "author": "lov3smu <imancoka@gmail.com>",
  "license": "MIT",
  "devDependencies": {
      "electron": "^27.3.11",
      "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "electron-log": "^5.0.1",
    "electron-updater": "^6.1.7"
  },
  "build": {
    "appId": "com.ancoka.sql-script-generator",
    "productName": "SQL Script Generator",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/*.log",
      "!**/.env",
      "!**/.md",
      "!assets/icon.icns",
      "!assets/icon.png",
      "!assets/icon.ico"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "publisherName": "lov3smu"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm", "tar.gz"],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "lov3smu",
      "repo": "sql-script-generator",
      "releaseType": "release"
    }
  }
}