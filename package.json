{
  "name": "sql-script-generator",
  "version": "1.0.3",
  "description": "SQL脚本生成工具，用于快速生成符合规范的SQL脚本文件。",
  "main": "src/main/index.js",
  "author": "lov3smu <imancoka@gmail.com>",
  "license": "MIT",
  "scripts": {
      "start": "electron .",
      "build": "echo 'Building...'",
      "build:linux": "electron-builder --linux --x64",
      "build:win": "electron-builder --win --x64",
      "build:mac": "electron-builder --mac --x64"
  },
  "devDependencies": {
      "electron": "^27.3.11",
      "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "electron-log": "^5.0.1",
    "electron-updater": "^6.1.7"
  },
  "build": {
    "appId": "com.ancoka.sql-script-generator",
    "productName": "SqlScriptGenerator",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "files": [
      "src/**/*",
      "package.json",
      "!**/*.log",
      "!**/.env",
      "!**/*.md",
      "assets/icon.icns",
      "assets/icon.png",
      "assets/icon.ico"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": {
        "target": "nsis",
        "arch": ["x64"]
      },
      "icon": "assets/icon.ico",
      "publisherName": "lov3smu"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm", "tar.gz"],
      "icon": "assets/icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
       "perMachine": true,
      "installerHeaderIcon": "assets/icon.ico",
      "license": "LICENSE.txt"
    },
    "publish": {
      "provider": "github",
      "owner": "lov3smu",
      "repo": "sql-script-generator",
      "releaseType": "release"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}